# TVMbot Environment Variables
# Copy this file to .env and fill in your values

# ── Anthropic (Claude) — REQUIRED ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OpenAI (ChatGPT) — REQUIRED for content gen + Anthropic fallback ─────────
# Used for: marketing content, general assistant, GPT fallback on Anthropic errors
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Server Port
PORT=3000

# Dashboard Login Credentials
LOGIN_USER=admin
LOGIN_PASSWORD=your-secure-password

# Session Secret (use a random string)
SESSION_SECRET=your-random-session-secret-here

# Timezone — Bali, Indonesia (WITA, UTC+8)
TZ=Asia/Makassar

# Telegram Bot Token (optional)
TELEGRAM_BOT_TOKEN=
