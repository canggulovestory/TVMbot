# TVMbot Environment Variables
# Copy this file to .env and fill in your values

# ── LLM API Keys ─────────────────────────────────────────────────────────────
# Anthropic (Claude) — REQUIRED for tool-use agent loop (Haiku/Sonnet only, no Opus)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (ChatGPT) — REQUIRED for content gen, planning, advice, Anthropic fallback
# Used by: planner, supervisor, marketing, guest_comms, general assistant
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
TZ=Asia/Makassar

# ── Auth & Security ──────────────────────────────────────────────────────────
# Dashboard login credentials (change these in production!)
LOGIN_USER=admin
LOGIN_PASSWORD=your-secure-password

# Session secret for express-session (use a long random string)
SESSION_SECRET=your-random-session-secret-here

# ── Google Workspace (configure in config/integrations.json) ─────────────────
# These go in config/integrations.json, NOT in .env:
#   gmail.client_id, gmail.client_secret, gmail.refresh_token
#   calendar.client_id, calendar.client_secret, calendar.refresh_token
#   drive.client_id, drive.client_secret, drive.refresh_token
#   sheets.client_id, sheets.client_secret, sheets.refresh_token
#
# How to get Google OAuth credentials:
#   1. Go to console.cloud.google.com → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Desktop app)
#   3. Use OAuth Playground (developers.google.com/oauthplayground) to get refresh_token
#   4. Create config/integrations.json with the credentials

# ── Messaging (optional) ─────────────────────────────────────────────────────
# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# WhatsApp uses Baileys (no API key needed — scans QR code from dashboard)
# WhatsApp session stored in whatsapp-session/ (gitignored)

# ── Notion (optional) ────────────────────────────────────────────────────────
# Configure in config/integrations.json under "notion" key
# NOTION_API_KEY goes in integrations.json, not here
